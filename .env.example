# OpenBenchmark 配置
# 本地开发: 复制本文件为 .env 并填入；`npm run benchmark` 会自动加载。
# CI: 不要用 .env，改在 Gitea Actions 的仓库 Secrets 里配置同名变量。
# 密钥绝不硬编码进代码，也绝不进入发布到 Pages 的产物。
# URL 不是机密，留空即用代码内的公开默认值。

# --- OpenCode Go ---
OPENCODE_GO_KEY=
OPENCODE_GO_URL=

# --- 智谱 AI ---
ZHIPU_API_KEY=
ZHIPU_URL=

# --- ChatGPT (zygtoken.com) ---
# 所有等级共用地址, 不同 Key 决定等级
CHATGPT_FREE_KEY=
CHATGPT_PLUS_FAST_KEY=
CHATGPT_PLUS_KEY=
CHATGPT_PRO_KEY=
CHATGPT_URL=

# --- DeepSeek 官方 ---
DEEPSEEK_API_KEY=
DEEPSEEK_URL=

# --- MiniMax 官方 ---
MINIMAX_API_KEY=
MINIMAX_URL=

# --- Gemini (第三方中转) ---
GEMINI_API_KEY=
GEMINI_URL=

# --- Claude (第三方中转) ---
CLAUDE_AWS_API_KEY=
CLAUDE_WS_API_KEY=
CLAUDE_MAX_API_KEY=

# --- 行为 ---
# 累积历史保留天数, 控制 data/results.ndjson 体积; 0 = 永久保留
RETENTION_DAYS=30

# ============================================================
# 仅 CI 部署需要 (放 Gitea Secrets, 不要写进本地 .env / 不要提交):
#   CLOUDFLARE_API_TOKEN   —— 含 Pages:Edit 权限的 API Token
#   CLOUDFLARE_ACCOUNT_ID  —— Cloudflare 账号 ID
# Pages 项目名在 wrangler.toml 的 name 字段 (默认 openbenchmark)。
# ============================================================
